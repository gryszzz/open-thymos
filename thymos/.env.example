# Thymos Server Configuration
# Copy this to .env and fill in your values.

# ── Cognition Providers ───────────────────────────────────────────────────────
# Set at least one key and runs that don't specify their own `cognition` block
# use that provider automatically (Anthropic preferred, then OpenAI). Confirm
# which one is active at GET /health -> "default_provider". Otherwise: mock.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Override the auto-detected default provider / model for runs that omit them.
# THYMOS_DEFAULT_PROVIDER accepts `anthropic`, `openai`, `mock`, or ANY preset
# name below (run `thymos providers` to list them all). THYMOS_DEFAULT_MODEL is
# optional; each preset has a sensible default.
# THYMOS_DEFAULT_PROVIDER=anthropic
# THYMOS_DEFAULT_MODEL=sonnet

# ── OpenAI-compatible presets — set the provider + its key, that's it ─────────
# Almost every model is reachable this way. Keys are read here, server-side;
# only the provider NAME is ever sent over the wire.
#   groq         GROQ_API_KEY=gsk_...
#   openrouter   OPENROUTER_API_KEY=sk-or-...
#   together     TOGETHER_API_KEY=...
#   deepseek     DEEPSEEK_API_KEY=...
#   mistral      MISTRAL_API_KEY=...
#   xai (grok)   XAI_API_KEY=...
#   fireworks    FIREWORKS_API_KEY=...
#   nvidia       NVIDIA_API_KEY=nvapi-...
#   cerebras     CEREBRAS_API_KEY=...
#   gemini       GEMINI_API_KEY=...   (or GOOGLE_API_KEY)
#   perplexity   PERPLEXITY_API_KEY=...
#   huggingface  HF_TOKEN=hf_...
# Local runtimes need no key: ollama | lmstudio | vllm | llamacpp | localai
# Example: THYMOS_DEFAULT_PROVIDER=groq with GROQ_API_KEY set below.
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...

# LM Studio (local OpenAI-compatible server — no auth needed)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=local-model
# LMSTUDIO_API_KEY=lm-studio

# Hugging Face Router (serverless inference, OpenAI-compatible)
# Generate a token at https://huggingface.co/settings/tokens
# (scope: "Make calls to Inference Providers")
# HF_TOKEN=hf_...
# HF_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# HF_BASE_URL=https://router.huggingface.co/v1

# ── Server ────────────────────────────────────────────────────────────────────
# THYMOS_RUNTIME_MODE=reference
# THYMOS_BIND_ADDR=0.0.0.0:3001
# THYMOS_ALLOWED_ORIGINS=http://localhost:3000
# THYMOS_LEDGER_PATH=thymos-ledger.db
# THYMOS_POSTGRES_URL=postgres://thymos:thymos@localhost:5432/thymos
# THYMOS_DB_PATH=thymos-runs.db
# THYMOS_GATEWAY_DB_PATH=thymos-gateway.db
# THYMOS_MARKETPLACE_DB_PATH=thymos-marketplace.db
# THYMOS_TOOL_FABRIC=in_process
# THYMOS_WORKER_BIN=/absolute/path/to/target/debug/thymos-worker
# Comma-separated dirs of JSON tool manifests loaded at startup:
# THYMOS_TOOL_MANIFEST_DIRS=../tools
# THYMOS_MAX_CONCURRENT_RUNS_GLOBAL=100
# THYMOS_MAX_CONCURRENT_RUNS_PER_TENANT=20

# ── API Gateway (optional) ────────────────────────────────────────────────────
# Comma-separated: key:tenant_id:name:rate_limit_rpm
# THYMOS_API_KEYS=sk-test-1:tenant-a:dev-key:60

# ── JWT Auth (optional) ──────────────────────────────────────────────────────
# THYMOS_JWT_SECRET=your-hmac-secret-at-least-32-bytes
# THYMOS_JWT_ISSUER=https://your-auth-provider.com
# THYMOS_JWT_AUDIENCE=thymos

# ── Observability (optional) ─────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# RUST_LOG=info

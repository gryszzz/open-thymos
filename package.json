{
  "name": "openthymos-runtime",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:preview": "npm run build && python3 -m http.server 4173 -d out",
    "doctor": "node scripts/doctor.mjs",
    "docs:check": "node scripts/check-docs.mjs",
    "site:check": "npm run build && npm run docs:check",
    "verify": "npm run typecheck && npm run build && npm run docs:check",
    "start": "next start",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.9.0"
  }
}
